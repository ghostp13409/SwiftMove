# ============================================================
# SwiftMove Production Environment Variables
# ============================================================

# Cloudflare Configuration
# IMPORTANT: Get this from dash.cloudflare.com -> Zero Trust -> Tunnels
CLOUDFLARE_TUNNEL_TOKEN=REPLACE_ME

# Spring Configuration
SPRING_PROFILES_ACTIVE=REPLACE_ME
PORT=REPLACE_ME

# PostgreSQL (Local Container)
POSTGRES_URI=REPLACE_ME
POSTGRES_USER=REPLACE_ME
POSTGRES_PASSWORD=REPLACE_ME
POSTGRES_DB=REPLACE_ME

# RabbitMQ
RABBITMQ_HOST=REPLACE_ME
RABBITMQ_PORT=REPLACE_ME
RABBITMQ_USER=REPLACE_ME
RABBITMQ_PASS=REPLACE_ME

# Eureka Discovery
EUREKA_URI=REPLACE_ME

# Auth / JWT (Change these to long random strings!)
JWT_SECRET=REPLACE_ME
JWT_EXPIRATION=REPLACE_ME

# Stripe (Add your keys for payments)
STRIPE_SECRET_KEY=REPLACE_ME
STRIPE_WEBHOOK_SECRET=REPLACE_ME

# Frontend Build
VITE_API_BASE_URL=REPLACE_ME
